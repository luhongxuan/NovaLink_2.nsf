<updatedby><name>CN=B11209013/O=XRedSchool</name></updatedby>
<wassignedby><name>CN=B11209013/O=XRedSchool</name></wassignedby><code event='options'><lotusscript
>Option Declare
Use "LNLKM01 VitalUtils"
</lotusscript></code><code event='postsave'><lotusscript>Sub Postsave(Source As Notesuidocument)
	Dim ss As New NotesSession
	Dim db As NotesDatabase
	Dim doc As NotesDocument

	Set db = ss.CurrentDatabase
	Set doc = Source.Document

	If doc.CoinIssued_Submit(0) &lt;&gt; "1" Then
		Call NLK_IssueCoin(db, doc.ProposerID(0), 5, "Proposal_Submit", _
			doc.UniversalID, "提出創新提案：" &amp; doc.ProposalTitle(0))
		doc.CoinIssued_Submit = "1"
		Call doc.Save(True, False)
	End If
End Sub
</lotusscript></code>
<actionbar bgcolor='#f0f0f0' bordercolor='black'>
<actionbuttonstyle bgcolor='#f0f0f0'/><font size='9pt' color='system'/><border
 style='solid' width='0px 0px 1px'/>
<action title='關閉'><code event='click'><formula>@Command([FileCloseWindow])</formula></code></action>
<action title='儲存'><code event='click'><formula>@Command([FileSave]);
@Command([FileCloseWindow])</formula></code></action>
<action title='公開提案'><code event='click'><formula>@If(Status = "Draft";
	@Do(
		@SetField("Status"; "Open");
		@Command([FileSave]);
		@Prompt([Ok]; "提案已公開"; "提案已公開，開始募集活力幣！")
	);
	@Prompt([Ok]; "無法操作"; "提案目前狀態為「" &amp; Status &amp; "」，無法公開。")
)</formula></code></action></actionbar>
