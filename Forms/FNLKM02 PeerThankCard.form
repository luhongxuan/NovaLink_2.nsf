<?xml version='1.0' encoding='utf-8'?>
<form name='FNLKM02 PeerThankCard' alias='FNLKM02' xmlns='http://www.lotus.com/dxl'
 version='12.0' maintenanceversion='2.0' replicaid='48258E12005A8210' publicaccess='false'
 designerversion='8.5.3' renderpassthrough='true'>
<noteinfo noteid='21e' unid='DFDB61CFA788566A48258E0C0042861B' sequence='19'>
<created><datetime>20260604T200637,07+08</datetime></created>
<modified><datetime>20260611T002836,46+08</datetime></modified>
<revised><datetime>20260609T134908,54+08</datetime></revised>
<lastaccessed><datetime>20260611T002836,45+08</datetime></lastaccessed>
<addedtofile><datetime>20260611T002836,45+08</datetime></addedtofile></noteinfo>
<updatedby><name>CN=B11209013/O=XRedSchool</name></updatedby>
<wassignedby><name>CN=B11209013/O=XRedSchool</name></wassignedby><code event='options'><lotusscript
>Option Declare
Use "LNLKM01 VitalUtils"
</lotusscript></code><code event='querysave'><lotusscript>Sub Querysave(Source As Notesuidocument, Continue As Variant)
	Dim ss As New NotesSession
	Dim recipID As String

	recipID = Trim(Source.FieldGetText("RecipientID"))
	If Lcase(recipID) = Lcase(Trim(ss.UserName)) Then
		Messagebox "不可以發感謝卡給自己！", 16, "操作錯誤"
		Continue = False
	End If
End Sub
</lotusscript></code><code event='postsave'><lotusscript>Sub Postsave(Source As Notesuidocument)
    Dim ss As New NotesSession
    Dim db As NotesDatabase
    Dim doc As NotesDocument
    Dim senderID As String
    Dim recipID As String
    Dim isPublic As String
    Dim cardType As String
    Dim senderCN As String
    Dim cardReadersArr(4) As String
    Dim emptyArr(0) As String

    Set db = ss.CurrentDatabase
    Set doc = Source.Document

    senderID = doc.SenderID(0)
    recipID  = doc.RecipientID(0)
    isPublic = doc.IsPublic(0)
    cardType = doc.CardType(0)
    senderCN = doc.SenderName(0)

    If isPublic = "0" Then
        cardReadersArr(0) = senderID
        cardReadersArr(1) = recipID
        cardReadersArr(2) = "[NLK_Manager]"
        cardReadersArr(3) = "[NLK_HR]"
        cardReadersArr(4) = "[NLK_SysAdmin]"
        doc.CardReaders = cardReadersArr
    Else
        emptyArr(0) = ""
        doc.CardReaders = emptyArr
    End If
    Call doc.Save(True, False)

    ' 這裡使用了 CDATA，所以可以直接寫 &lt;&gt; 和 &amp;，不會再報錯了！
    If doc.CoinIssued(0) &lt;&gt; "1" Then
        Call NLK_IssueCoin(db, senderID, 2, "ThanksCard_Send", doc.UniversalID, _
            "發送感謝卡（" &amp; cardType &amp; "）")
        Call NLK_IssueCoin(db, recipID, 3, "ThanksCard_Recv", doc.UniversalID, _
            "收到感謝卡（" &amp; cardType &amp; "）")
        doc.CoinIssued = "1"
        Call doc.Save(True, False)
    End If

    Call NLK_SendNotifyMail(recipID, _
        "您收到一張感謝卡！", _
        senderCN &amp; " 傳送了一張「" &amp; cardType &amp; "」感謝卡給您。")
End Sub
</lotusscript></code>
