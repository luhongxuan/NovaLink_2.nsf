<designchange><datetime>20260609T134907,78+08</datetime></designchange>
<trigger type='actionsmenu'/>
<documentset type='selected'/><code event='options'><lotusscript>Option Public
Option Declare
Use "LNLKM01 VitalUtils"

</lotusscript></code><code event='initialize'><lotusscript>Sub Initialize
	Dim ss As New NotesSession
	Dim db As NotesDatabase
	Dim view As NotesView
	Dim doc As NotesDocument
	Dim nextDoc As NotesDocument
	Dim currentCoins As Long
	Dim targetCoins As Long

	Set db = ss.CurrentDatabase
	Set view = db.GetView("VNLKM30")
	If view Is Nothing Then Exit Sub

	Set doc = view.GetFirstDocument()
	Do While Not (doc Is Nothing)
		Set nextDoc = view.GetNextDocument(doc)

		If doc.Status(0) = "Open" Then
			currentCoins = Clng(doc.CurrentCoins(0))
			targetCoins  = Clng(doc.TargetCoins(0))

			If currentCoins &gt;= targetCoins And targetCoins &gt; 0 Then
				doc.Status = "Pending"
				Call doc.Save(True, False)

				If doc.CoinIssued_Funded(0) &lt;&gt; "1" Then
					Call NLK_IssueCoin(db, doc.ProposerID(0), 50, "Proposal_Funded", _
						doc.UniversalID, "提案達標：" &amp; doc.ProposalTitle(0))
					doc.CoinIssued_Funded = "1"
					Call doc.Save(True, False)
				End If

				Call NLK_SendNotifyMail(doc.ProposerID(0), _
					"您的提案已達標！", _
					"提案「" &amp; doc.ProposalTitle(0) &amp; "」已達到目標，進入審核，並獲得 +50 活力幣！")
			End If
		End If

		Set doc = nextDoc
	Loop
End Sub</lotusscript></code></agent>

